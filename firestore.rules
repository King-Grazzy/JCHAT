rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write their own data
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to read and write public data
    match /public/data/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write chat data
    match /public/data/chat_rooms/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /public/data/chats/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /public/data/groups/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write presence data
    match /public/data/presence/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write typing data
    match /public/data/typing/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write system settings
    match /system_settings/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write posts
    match /posts/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write comments
    match /comments/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write reactions
    match /reactions/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write stories
    match /stories/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write calls
    match /calls/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write friends
    match /friends/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write saved posts
    match /saved_posts/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write streaks
    match /streaks/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write spin data
    match /spin/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write user profiles
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to read and write user entitlements
    match /user_entitlements/{userId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}