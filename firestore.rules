rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEVELOPMENT RULES - Allow all access for demo user
    // WARNING: These rules are for development only and should be restricted for production
    
    // Allow read/write access to all collections
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Alternative: More restrictive but still allows demo access
    // match /artifacts/{appId}/users/{userId}/{document=**} {
    //   allow read, write: if true;
    // }
    
    // match /public/data/{document=**} {
    //   allow read, write: if true;
    // }
    
    // match /{document=**} {
    //   allow read, write: if true;
    // }
  }
}